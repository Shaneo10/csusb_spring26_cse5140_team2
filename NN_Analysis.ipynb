   "source": [
    "## 2.2 Hyperparameter Training"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "18118e64-f638-402d-9a6e-a5cff00f03c9",
   "metadata": {},
   "source": [
    "We will:\n",
    "- Run 30 trials random search \n",
    "- Tune:\n",
    "    - Hidden layer size\n",
    "    - Dropout \n",
    "    - Learning rate \n",
    "    - Weight Decay\n",
    "- Use validation set only \n",
    "- Select the best model (save it -- weights, biases, hyperparameter settings)\n",
    "- Do NOT touch final holdout "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 28,
   "id": "62b81f9e-03d8-4331-bb01-3b8e33613545",
   "metadata": {
    "tags": []
   },
   "outputs": [],
   "source": [
    "# ==================================\n",
    "# 2.2 Hyperparameter Tuning\n",
    "# ==================================\n",
    "\n",
    "# Function to train and validate a neural network with given hyperparameters.\n",
    "# Returns validation loss and the trained model.\n",
    "def train_and_validate(hidden_dim, dropout, lr, weight_decay, epochs=20):\n",
    "    \n",
    "    # Initialize base model with correct input dimension\n",
    "    model = TabularNN(input_dim).to(device)\n",
    "    \n",
    "    # Dynamically redefine the architecture based on hyperparameters.\n",
    "    # hidden_dim controls first layer width.\n",
    "    # Second hidden layer is half the size of the first.\n",
    "    # dropout controls regularization strength.\n",
    "    model.model = nn.Sequential(\n",
    "        nn.Linear(input_dim, hidden_dim),\n",
    "        nn.ReLU(),\n",
    "        nn.Dropout(dropout),\n",
    "        \n",
    "        nn.Linear(hidden_dim, hidden_dim // 2),\n",
    "        nn.ReLU(),\n",
    "        nn.Dropout(dropout),\n",
    "        \n",
    "        nn.Linear(hidden_dim // 2, 1)\n",
    "    )\n",
    "    \n",
    "    # Ensure model is on correct device after modifying architecture\n",
    "    model = model.to(device)\n",
    "    \n",
    "    # Define optimizer with variable learning rate and weight decay\n",
    "    optimizer = torch.optim.Adam(\n",
    "        model.parameters(),\n",
    "        lr=lr,                  # Learning rate hyperparameter\n",
    "        weight_decay=weight_decay  # L2 regularization strength\n",
    "    )\n",
    "    \n",
    "    # Use Mean Squared Error for regression\n",
    "    criterion = nn.MSELoss()\n",
    "    \n",
    "    # Training loop\n",
    "    for epoch in range(epochs):\n",
    "        model.train()  # Enable training mode (dropout active)\n",
    "        \n",
    "        for xb, yb in train_loader:\n",
    "            # Move batch to device\n",
    "            xb, yb = xb.to(device), yb.to(device)\n",
    "            \n",
    "            # Forward pass\n",
    "            preds = model(xb)\n",
    "            \n",
    "            # Compute loss\n",
    "            loss = criterion(preds, yb)\n",
    "            \n",
    "            # Reset gradients\n",
    "            optimizer.zero_grad()\n",
    "            \n",
    "            # Backpropagation\n",
    "            loss.backward()\n",
    "            \n",
    "            # Update weights\n",
    "            optimizer.step()\n",
    "    \n",
    "    # After training, evaluate on validation set\n",
    "    model.eval()  # Disable dropout\n",
    "    val_loss = 0\n",
    "    \n",
    "    # Disable gradient computation for validation\n",
    "    with torch.no_grad():\n",
    "        for xb, yb in val_loader:\n",
    "            xb, yb = xb.to(device), yb.to(device)\n",
    "            \n",
    "            # Forward pass only\n",
    "            preds = model(xb)\n",
    "            \n",
    "            # Accumulate validation loss\n",
    "            val_loss += criterion(preds, yb).item()\n",
    "    \n",
    "    # Compute average validation loss\n",
    "    val_loss /= len(val_loader)\n",
    "    \n",
    "    # Return validation loss and trained model\n",
    "    return val_loss, model\n"
   ]
  },
