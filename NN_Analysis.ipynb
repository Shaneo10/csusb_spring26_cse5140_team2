   "source": [
    "# converts start latitude and longitude to Manhattan distance  \n",
    "# A function that computes Manhattan distance between two geographic points.\n",
    "# Manhattan distance is used because bike trips follow a road network\n",
    "# rather than straight-line (Euclidean) distance.\n",
    "def manhattan_distance(lat1, lon1, lat2, lon2):\n",
    "    \"\"\" Takes as input start (latitude, longitude) and end (latitude, longitude) --> outputs manhattan distance \"\"\"\n",
    "    \"\"\" Manhattan Distance = |end_latitude - start_latitude| + |end_longitude - start_longitude|\"\"\"\n",
    "    \"\"\" Logic is bike trips happen on Chicago road-network and we believe this is the most appropriate distance function\"\"\"\n",
    "    \n",
    "    # Compute absolute differences in latitude and longitude (in degrees)\n",
    "    dlat = np.abs(lat1 - lat2)\n",
    "    dlon = np.abs(lon1 - lon2)\n",
    "    \n",
    "    # Convert degree differences to kilometers.\n",
    "    # 1 degree latitude ≈ 111 km.\n",
    "    lat_km = dlat * 111\n",
    "    \n",
    "    # Longitude distance depends on latitude (Earth curvature adjustment).\n",
    "    lon_km = dlon * 111 * np.cos(np.radians((lat1 + lat2) / 2))\n",
    "    \n",
    "    # Manhattan distance = north-south distance + east-west distance\n",
    "    return lat_km + lon_km\n",
    "\n",
    "\n",
    "# -------------------------------------------------\n",
    "# TRAIN PREPROCESSING\n",
    "# -------------------------------------------------\n",
    "from sklearn.preprocessing import StandardScaler, OneHotEncoder\n",
    "\n",
    "\n",
    "def preprocess_trip_data(\n",
    "    X,\n",
    "    y=None,\n",
    "    fit=True,\n",
    "    scaler=None,\n",
    "    encoder=None,\n",
    "    station_to_idx=None\n",
    "):\n",
    "    \"\"\"\n",
    "    Convert raw trip data into engineered model-ready features.\n",
    "    \n",
    "    Steps include:\n",
    "    - Feature engineering (spatial, temporal, behavioral, weather)\n",
    "    - One-hot encoding categorical variables\n",
    "    - Station ID indexing for embedding usage\n",
    "    - Scaling numeric features\n",
    "    - Log-transforming target variable\n",
    "    \"\"\"\n",
    "    \n",
    "    # Work on a copy to avoid modifying original dataset\n",
    "    X = X.copy()\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 1️⃣ Drop irrelevant columns\n",
    "    # -------------------------------------------------\n",
    "    # Remove unused identifiers or redundant columns\n",
    "    drop_cols = [\n",
    "        \"level_0\",\n",
    "        \"index\",\n",
    "        \"from_station_name\",\n",
    "        \"to_station_name\"\n",
    "    ]\n",
    "    X = X.drop(columns=[c for c in drop_cols if c in X.columns])\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 2️⃣ Distance & Direction\n",
    "    # -------------------------------------------------\n",
    "    # Create Manhattan distance feature\n",
    "    X[\"distance_km\"] = manhattan_distance(\n",
    "        X[\"latitude_start\"],\n",
    "        X[\"longitude_start\"],\n",
    "        X[\"latitude_end\"],\n",
    "        X[\"longitude_end\"]\n",
    "    )\n",
    "\n",
    "    # Directional components\n",
    "    X[\"delta_lat\"] = X[\"latitude_end\"] - X[\"latitude_start\"]\n",
    "    X[\"delta_lon\"] = X[\"longitude_end\"] - X[\"longitude_start\"]\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 3️⃣ Capacity Features\n",
    "    # -------------------------------------------------\n",
    "    # Absolute and relative capacity differences between stations\n",
    "    X[\"capacity_diff\"] = X[\"dpcapacity_end\"] - X[\"dpcapacity_start\"]\n",
    "    X[\"capacity_ratio\"] = X[\"dpcapacity_end\"] / (X[\"dpcapacity_start\"] + 1e-6)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 4️⃣ Cyclical Time Encoding\n",
    "    # -------------------------------------------------\n",
    "    # Encode time variables using sine/cosine to preserve periodic structure\n",
    "    X[\"hour_sin\"] = np.sin(2 * np.pi * X[\"hour\"] / 24)\n",
    "    X[\"hour_cos\"] = np.cos(2 * np.pi * X[\"hour\"] / 24)\n",
    "\n",
    "    X[\"month_sin\"] = np.sin(2 * np.pi * X[\"month\"] / 12)\n",
    "    X[\"month_cos\"] = np.cos(2 * np.pi * X[\"month\"] / 12)\n",
    "\n",
    "    X[\"week_sin\"] = np.sin(2 * np.pi * X[\"week\"] / 52)\n",
    "    X[\"week_cos\"] = np.cos(2 * np.pi * X[\"week\"] / 52)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 5️⃣ Behavioral Indicators\n",
    "    # -------------------------------------------------\n",
    "    # Weekend indicator (Saturday=5, Sunday=6)\n",
    "    X[\"is_weekend\"] = X[\"day\"].isin([5, 6]).astype(int)\n",
    "\n",
    "    # Rush hour indicator\n",
    "    X[\"is_rush_hour\"] = X[\"hour\"].isin([7,8,9,16,17,18,19]).astype(int)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 6️⃣ Weather Features\n",
    "    # -------------------------------------------------\n",
    "    # Add nonlinear temperature term\n",
    "    X[\"temp_squared\"] = X[\"temperature\"] ** 2\n",
    "\n",
    "    # Cold and hot binary flags\n",
    "    X[\"is_cold\"] = (X[\"temperature\"] < 5).astype(int)\n",
    "    X[\"is_hot\"] = (X[\"temperature\"] > 30).astype(int)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 7️⃣ Same Station Flag\n",
    "    # -------------------------------------------------\n",
    "    # Flag trips that start and end at same station\n",
    "    X[\"same_station\"] = (\n",
    "        X[\"from_station_id\"] == X[\"to_station_id\"]\n",
    "    ).astype(int)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 8️⃣ Log Transform Target\n",
    "    # -------------------------------------------------\n",
    "    # Apply log(1 + y) transform for stability\n",
    "    if y is not None:\n",
    "        y_log = np.log1p(y)\n",
    "    else:\n",
    "        y_log = None\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 9️⃣ Station Embedding Mapping\n",
    "    # -------------------------------------------------\n",
    "    # Create station ID → index mapping (only when fitting)\n",
    "    if fit:\n",
    "        all_stations = pd.concat([\n",
    "            X[\"from_station_id\"],\n",
    "            X[\"to_station_id\"]\n",
    "        ]).unique()\n",
    "\n",
    "        station_to_idx = {\n",
    "            station_id: idx for idx, station_id in enumerate(all_stations)\n",
    "        }\n",
    "\n",
    "    # Map station IDs to indices (unknown stations → -1)\n",
    "    X[\"from_station_idx\"] = X[\"from_station_id\"].map(station_to_idx).fillna(-1).astype(int)\n",
    "    X[\"to_station_idx\"] = X[\"to_station_id\"].map(station_to_idx).fillna(-1).astype(int)\n",
    "\n",
    "    num_stations = len(station_to_idx)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 🔟 One-Hot Encode Small Categoricals\n",
    "    # -------------------------------------------------\n",
    "    categorical_cols = [\"usertype\", \"gender\", \"events\"]\n",
    "\n",
    "    if fit:\n",
    "        encoder = OneHotEncoder(handle_unknown=\"ignore\", sparse=False)\n",
    "        encoded_array = encoder.fit_transform(X[categorical_cols])\n",
    "    else:\n",
    "        encoded_array = encoder.transform(X[categorical_cols])\n",
    "\n",
    "    # Convert encoded array back to DataFrame\n",
    "    encoded_df = pd.DataFrame(\n",
    "        encoded_array,\n",
    "        columns=encoder.get_feature_names_out(categorical_cols),\n",
    "        index=X.index\n",
    "    )\n",
    "\n",
    "    # Drop original categorical columns and concatenate encoded features\n",
    "    X = X.drop(columns=categorical_cols)\n",
    "    X = pd.concat([X, encoded_df], axis=1)\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 1️⃣1️⃣ Drop redundant raw features\n",
    "    # -------------------------------------------------\n",
    "    redundant_cols = [\n",
    "        \"latitude_start\",\n",
    "        \"longitude_start\",\n",
    "        \"latitude_end\",\n",
    "        \"longitude_end\",\n",
    "        \"from_station_id\",\n",
    "        \"to_station_id\",\n",
    "        \"hour\",\n",
    "        \"month\",\n",
    "        \"week\",\n",
    "        \"year\"\n",
    "    ]\n",
    "\n",
    "    X = X.drop(columns=[c for c in redundant_cols if c in X.columns])\n",
    "\n",
    "    # -------------------------------------------------\n",
    "    # 1️⃣2️⃣ Scale numeric features\n",
    "    # -------------------------------------------------\n",
    "    # Identify numeric columns\n",
    "    numeric_cols = X.select_dtypes(include=[\"float64\", \"int64\"]).columns.tolist()\n",
    "\n",
    "    # Exclude categorical indicators and embedding indices from scaling\n",
    "    exclude_cols = [\n",
    "        \"from_station_idx\",\n",
    "        \"to_station_idx\",\n",
    "        \"is_weekend\",\n",
    "        \"is_rush_hour\",\n",
    "        \"is_cold\",\n",
    "        \"is_hot\",\n",
    "        \"same_station\"\n",
    "    ]\n",
    "\n",
    "    numeric_cols = [c for c in numeric_cols if c not in exclude_cols]\n",
    "\n",
    "    # Fit scaler on training data only\n",
    "    if fit:\n",
    "        scaler = StandardScaler()\n",
    "        X[numeric_cols] = scaler.fit_transform(X[numeric_cols])\n",
    "    else:\n",
    "        X[numeric_cols] = scaler.transform(X[numeric_cols])\n",
    "\n",
    "    # Return outputs depending on fit mode\n",
    "    if fit:\n",
    "        return X, y_log, scaler, encoder, station_to_idx, num_stations\n",
    "    else:\n",
    "        return X, y_log"
   ]
