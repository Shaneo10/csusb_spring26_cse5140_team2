    "# ==========================================\n",
    "# Bootstrap Hypothesis Testing (TEST SET)\n",
    "# Using Already-Trained Models\n",
    "# ==========================================\n",
    "# Number of bootstrap iterations\n",
    "# 1000 provides stable confidence interval estimates\n",
    "B = 1000\n",
    "\n",
    "# Random number generator (seeded for reproducibility)\n",
    "rng = np.random.default_rng(SEED)\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 1️⃣ Prepare Test Features\n",
    "# --------------------------------------------------\n",
    "\n",
    "# Linear models do NOT use station embedding indices,\n",
    "# so we remove those columns before prediction.\n",
    "# errors=\"ignore\" prevents crashing if columns are absent.\n",
    "X_test_lin = X_test_processed.drop(\n",
    "    columns=[\"from_station_idx\", \"to_station_idx\"],\n",
    "    errors=\"ignore\"\n",
    ")\n",
    "\n",
    "# Convert true test targets (log space) to NumPy array.\n",
    "# reshape(-1) ensures 1D shape for vectorized operations.\n",
    "y_true = np.asarray(y_test_log).astype(float).reshape(-1)\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 2️⃣ Generate Predictions (NO RETRAINING)\n",
    "# --------------------------------------------------\n",
    "\n",
    "# Generate predictions from already-trained baseline models.\n",
    "# These models were fitted earlier in the notebook.\n",
    "lin_pred = model_Linear.predict(X_test_lin)\n",
    "ridge_pred = ridge_cv.predict(X_test_lin)\n",
    "lasso_pred = lasso_cv.predict(X_test_lin)\n",
    "\n",
    "# Prepare neural network for inference.\n",
    "# eval() disables dropout and training-specific behavior.\n",
    "loaded_model.eval()\n",
    "\n",
    "# Convert test features to PyTorch tensor for NN prediction.\n",
    "# Move to appropriate device (CPU or GPU).\n",
    "X_test_tensor = torch.tensor(\n",
    "    X_test_processed.values,\n",
    "    dtype=torch.float32\n",
    ").to(device)\n",
    "\n",
    "# Disable gradient tracking (faster + memory efficient).\n",
    "with torch.no_grad():\n",
    "    # Generate NN predictions and convert back to NumPy array.\n",
    "    nn_pred = loaded_model(X_test_tensor).cpu().numpy().reshape(-1)\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 3️⃣ Bootstrap Error Differences\n",
    "# --------------------------------------------------\n",
    "\n",
    "# Store baseline predictions in dictionary for iteration.\n",
    "baseline_preds = {\n",
    "    \"Linear Regression\": lin_pred,\n",
    "    \"Ridge\": ridge_pred,\n",
    "    \"Lasso\": lasso_pred,\n",
    "}\n",
    "\n",
    "# Number of test observations\n",
    "n = len(y_true)\n",
    "\n",
    "# Container for final bootstrap results\n",
    "bootstrap_results = []\n",
    "\n",
    "# Loop through each baseline model and compare against NN\n",
    "for name, baseline_pred in baseline_preds.items():\n",
    "    \n",
    "    # Store bootstrap mean differences for this model\n",
    "    diffs = np.zeros(B)\n",
    "    \n",
    "    # Perform B bootstrap resamples\n",
    "    for b in range(B):\n",
    "        \n",
    "        # Sample indices with replacement from test set\n",
    "        idx = rng.integers(0, n, n)\n",
    "        \n",
    "        # Resampled true values and predictions\n",
    "        y_sample = y_true[idx]\n",
    "        base_sample = baseline_pred[idx]\n",
    "        nn_sample = nn_pred[idx]\n",
    "        \n",
    "        # Compute absolute prediction errors\n",
    "        base_err = np.abs(y_sample - base_sample)\n",
    "        nn_err = np.abs(y_sample - nn_sample)\n",
    "        \n",
    "        # Compute mean absolute error difference:\n",
    "        # Positive value → NN performs better\n",
    "        diffs[b] = np.mean(base_err - nn_err)\n",
    "    \n",
    "    # Compute bootstrap statistics\n",
    "    mean_diff = diffs.mean()  # Average improvement\n",
    "    ci_lower = np.percentile(diffs, 2.5)   # Lower bound (95% CI)\n",
    "    ci_upper = np.percentile(diffs, 97.5)  # Upper bound (95% CI)\n",
    "    \n",
    "    # One-sided empirical p-value:\n",
    "    # Probability that NN does NOT outperform baseline\n",
    "    p_value = np.mean(diffs <= 0)\n",
    "    \n",
    "    # Store formatted results\n",
    "    bootstrap_results.append([\n",
    "        name,\n",
    "        f\"{mean_diff:.6f}\",\n",
    "        f\"{ci_lower:.6f}\",\n",
    "        f\"{ci_upper:.6f}\",\n",
    "        f\"{p_value:.6g}\"\n",
    "    ])\n",
    "\n",
    "# Construct final results table\n",
    "bootstrap_table = pd.DataFrame(\n",
    "    bootstrap_results,\n",
    "    columns=[\n",
    "        \"Baseline Model\",\n",
    "        \"Mean Abs Error Diff (Baseline - NN)\",\n",
    "        \"95% CI Lower\",\n",
    "        \"95% CI Upper\",\n",
    "        \"Empirical p-value\"\n",
    "    ]\n",
    ")\n",
    "\n",
    "# Display results\n",
    "print(\"========================================\")\n",
    "print(\"Bootstrap Results (TEST SET)\")\n",
    "print(\"========================================\")\n",
    "display(bootstrap_table)"
   ]
