    "# ===============================\n",
    "# 2.1 Neural Network Architecture\n",
    "# ===============================\n",
    "\n",
    "# Select device for training:\n",
    "# Use GPU (cuda) if available for faster computation,\n",
    "# otherwise default to CPU.\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "# Convert processed training features from pandas DataFrame to PyTorch tensor.\n",
    "# dtype=torch.float32 ensures compatibility with neural network layers.\n",
    "X_train_tensor = torch.tensor(x_train_processed.values, dtype=torch.float32)\n",
    "\n",
    "# Convert log-transformed training target to tensor.\n",
    "# .view(-1,1) reshapes it into a column vector (required for regression output).\n",
    "y_train_tensor = torch.tensor(y_train_log.values, dtype=torch.float32).view(-1,1)\n",
    "\n",
    "# Convert validation/test features to tensor.\n",
    "X_val_tensor = torch.tensor(x_test_processed.values, dtype=torch.float32)\n",
    "\n",
    "# Convert validation/test target to tensor and reshape to column vector.\n",
    "y_val_tensor = torch.tensor(y_test_log.values, dtype=torch.float32).view(-1,1)\n",
    "\n",
    "# Create TensorDataset objects to pair inputs and targets together.\n",
    "# This allows DataLoader to iterate over batches.\n",
    "train_dataset = TensorDataset(X_train_tensor, y_train_tensor)\n",
    "val_dataset = TensorDataset(X_val_tensor, y_val_tensor)\n",
    "\n",
    "# Create a PyTorch random generator for reproducibility.\n",
    "# This ensures consistent shuffling behavior across runs.\n",
    "g = torch.Generator()\n",
    "g.manual_seed(SEED)\n",
    "\n",
    "# Create DataLoader for training data:\n",
    "# - batch_size=256 controls number of samples per gradient update\n",
    "# - shuffle=True randomizes data order each epoch\n",
    "# - generator=g ensures deterministic shuffling with fixed seed\n",
    "train_loader = DataLoader(train_dataset, batch_size=256, shuffle=True, generator=g)\n",
    "\n",
    "# Create DataLoader for validation data:\n",
    "# - No shuffling needed for evaluation\n",
    "# - Same batch size for consistency\n",
    "val_loader = DataLoader(val_dataset, batch_size=256)"
   ]
