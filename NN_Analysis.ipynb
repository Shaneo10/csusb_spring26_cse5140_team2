  {
   "cell_type": "markdown",
   "id": "d742b90a-fbb1-41ad-8266-576b5d57b0e5",
   "metadata": {},
   "source": [
    "### Training Loop "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "8c46b4c3-4c0b-465f-8a92-9c7fd3719f19",
   "metadata": {
    "tags": []
   },
   "outputs": [],
   "source": [
    "# Define training function for the neural network.\n",
    "# Trains the model for a specified number of epochs and\n",
    "# reports both training and validation loss.\n",
    "def train_nn(model, train_loader, val_loader, epochs=20):\n",
    "    \n",
    "    # Loop over epochs\n",
    "    for epoch in range(epochs):\n",
    "        \n",
    "        # Set model to training mode.\n",
    "        # Enables dropout and other training-specific behavior.\n",
    "        model.train()\n",
    "        train_loss = 0\n",
    "        \n",
    "        # Iterate over training batches\n",
    "        for xb, yb in train_loader:\n",
    "            \n",
    "            # Move batch data to selected device (CPU/GPU)\n",
    "            xb, yb = xb.to(device), yb.to(device)\n",
    "            \n",
    "            # Forward pass: compute predictions\n",
    "            preds = model(xb)\n",
    "            \n",
    "            # Compute loss between predictions and true values\n",
    "            loss = criterion(preds, yb)\n",
    "            \n",
    "            # Reset gradients from previous step\n",
    "            optimizer.zero_grad()\n",
    "            \n",
    "            # Backward pass: compute gradients\n",
    "            loss.backward()\n",
    "            \n",
    "            # Update model parameters\n",
    "            optimizer.step()\n",
    "            \n",
    "            # Accumulate training loss\n",
    "            train_loss += loss.item()\n",
    "        \n",
    "        # Switch model to evaluation mode.\n",
    "        # Disables dropout and stops updating batchnorm statistics.\n",
    "        model.eval()\n",
    "        val_loss = 0\n",
    "        \n",
    "        # Disable gradient computation for validation (faster & memory efficient)\n",
    "        with torch.no_grad():\n",
    "            for xb, yb in val_loader:\n",
    "                \n",
    "                # Move validation batch to device\n",
    "                xb, yb = xb.to(device), yb.to(device)\n",
    "                \n",
    "                # Forward pass only (no backprop)\n",
    "                preds = model(xb)\n",
    "                \n",
    "                # Accumulate validation loss\n",
    "                val_loss += criterion(preds, yb).item()\n",
    "        \n",
    "        # Print average training and validation loss for this epoch\n",
    "        print(f\"Epoch {epoch+1}: \"\n",
    "              f\"Train Loss={train_loss/len(train_loader):.4f}, \"\n",
    "              f\"Val Loss={val_loss/len(val_loader):.4f}\")"
   ]
  },
