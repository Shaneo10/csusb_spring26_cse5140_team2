   "source": [
    "# Determine the number of input features.\n",
    "# This corresponds to the number of columns in the processed training data.\n",
    "input_dim = X_train_tensor.shape[1]\n",
    "\n",
    "# Initialize the neural network model with the correct input dimension.\n",
    "# Move the model to the selected device (CPU or GPU).\n",
    "model = TabularNN(input_dim).to(device)\n",
    "\n",
    "# Define the loss function.\n",
    "# Mean Squared Error (MSE) is standard for regression tasks.\n",
    "criterion = nn.MSELoss()\n",
    "\n",
    "# Initialize the optimizer.\n",
    "# Adam is an adaptive learning rate optimization algorithm.\n",
    "optimizer = torch.optim.Adam(\n",
    "    model.parameters(),  # Parameters to update during training\n",
    "    lr=1e-3,             # Initial learning rate (step size)\n",
    "    weight_decay=1e-4    # L2 regularization term to reduce overfitting\n",
    ")"
