   "source": [
    "# Define a neural network class for tabular regression tasks.\n",
    "# Inherits from torch.nn.Module.\n",
    "class TabularNN(nn.Module):\n",
    "    def __init__(self, input_dim):\n",
    "        # Initialize parent class (required for all nn.Module subclasses)\n",
    "        super().__init__()\n",
    "        \n",
    "        # Define the model architecture using nn.Sequential\n",
    "        # This stacks layers in the specified order.\n",
    "        self.model = nn.Sequential(\n",
    "            # First fully connected layer:\n",
    "            # Maps input features → 128 hidden units\n",
    "            nn.Linear(input_dim, 128),   # Hidden layer 1\n",
    "            \n",
    "            # Nonlinear activation function\n",
    "            nn.ReLU(),\n",
    "            \n",
    "            # Dropout for regularization (randomly zeroes 30% of activations)\n",
    "            # Helps reduce overfitting\n",
    "            nn.Dropout(0.3),\n",
    "            \n",
    "            # Second fully connected layer:\n",
    "            # 128 → 64 hidden units\n",
    "            nn.Linear(128, 64),          # Hidden layer 2\n",
    "            \n",
    "            # Nonlinear activation\n",
    "            nn.ReLU(),\n",
    "            \n",
    "            # Dropout regularization again\n",
    "            nn.Dropout(0.3),\n",
    "            \n",
    "            # Final output layer:\n",
    "            # 64 → 1 output (single continuous value for regression)\n",
    "            nn.Linear(64, 1)             # Output layer (regression)\n",
    "        )\n",
    "\n",
    "    # Define forward pass (how input flows through network)\n",
    "    def forward(self, x):\n",
    "        # Pass input through the sequential model\n",
    "        return self.model(x)"
   ]
  },
