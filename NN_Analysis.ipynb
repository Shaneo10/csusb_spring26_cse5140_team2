    "# =========================\n",
    "# Reproducibility Settings\n",
    "# =========================\n",
    "\n",
    "# Set a fixed random seed value.\n",
    "# Using the same seed ensures consistent results across runs.\n",
    "SEED = 42\n",
    "\n",
    "# -------------------------\n",
    "# Python random module\n",
    "# -------------------------\n",
    "# Controls randomness for Python’s built-in random functions.\n",
    "random.seed(SEED)\n",
    "\n",
    "# -------------------------\n",
    "# NumPy random\n",
    "# -------------------------\n",
    "# Ensures reproducibility for NumPy-based randomness\n",
    "# (e.g., shuffling, random sampling, initialization).\n",
    "np.random.seed(SEED)\n",
    "\n",
    "# -------------------------\n",
    "# PyTorch CPU\n",
    "# -------------------------\n",
    "# Sets seed for CPU-based tensor operations and model initialization.\n",
    "torch.manual_seed(SEED)\n",
    "\n",
    "# -------------------------\n",
    "# PyTorch GPU\n",
    "# -------------------------\n",
    "# Sets seed for CUDA operations (if GPU is used).\n",
    "torch.cuda.manual_seed(SEED)\n",
    "torch.cuda.manual_seed_all(SEED)\n",
    "\n",
    "# -------------------------\n",
    "# CUDA Determinism Settings\n",
    "# -------------------------\n",
    "# Forces deterministic behavior in CuDNN operations.\n",
    "# deterministic=True ensures repeatable results.\n",
    "# benchmark=False prevents runtime algorithm selection variability.\n",
    "torch.backends.cudnn.deterministic = True\n",
    "torch.backends.cudnn.benchmark = False\n",
    "\n",
    "# Confirmation message\n",
    "print(\"Seeds set for reproducibility.\")"
   ]
