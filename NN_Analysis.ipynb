   "source": [
    "# Number of random hyperparameter trials to run.\n",
    "# Typically 20–50 is reasonable for small-scale tuning.\n",
    "num_trials = 30  # 20–50 allowed\n",
    "\n",
    "# Initialize best validation loss as infinity so any real loss will be smaller.\n",
    "best_val_loss = float(\"inf\")\n",
    "\n",
    "# Placeholders to store the best-performing model and its configuration.\n",
    "best_model = None\n",
    "best_config = None\n",
    "\n",
    "# Set random seeds for reproducibility across:\n",
    "# - Python's random module\n",
    "# - NumPy\n",
    "# - PyTorch (CPU)\n",
    "# - PyTorch (GPU)\n",
    "random.seed(SEED)\n",
    "np.random.seed(SEED)\n",
    "torch.manual_seed(SEED)\n",
    "torch.cuda.manual_seed_all(SEED)\n",
    "\n",
    "# Begin random search over hyperparameters\n",
    "for trial in range(num_trials):\n",
    "    \n",
    "    # Randomly sample hyperparameters from predefined candidate sets\n",
    "    hidden_dim = random.choice([64, 128, 256])        # Hidden layer width\n",
    "    dropout = random.choice([0.2, 0.3, 0.4])          # Dropout regularization\n",
    "    lr = random.choice([1e-3, 5e-4, 1e-4])            # Learning rate\n",
    "    weight_decay = random.choice([1e-3, 1e-4, 1e-5])  # L2 regularization\n",
    "    \n",
    "    # Train model with selected hyperparameters and obtain validation loss\n",
    "    val_loss, model = train_and_validate(\n",
    "        hidden_dim,\n",
    "        dropout,\n",
    "        lr,\n",
    "        weight_decay,\n",
    "        epochs=20\n",
    "    )\n",
    "    \n",
    "    # Print trial summary for monitoring progress\n",
    "    print(f\"Trial {trial+1}/{num_trials} | \"\n",
    "          f\"Val Loss: {val_loss:.4f} | \"\n",
    "          f\"Hidden: {hidden_dim} | \"\n",
    "          f\"Dropout: {dropout} | \"\n",
    "          f\"LR: {lr} | \"\n",
    "          f\"WD: {weight_decay}\")\n",
    "    \n",
    "    # If current model performs better than previous best, update trackers\n",
    "    if val_loss < best_val_loss:\n",
    "        best_val_loss = val_loss\n",
    "        \n",
    "        # Deep copy ensures the best model weights are preserved\n",
    "        best_model = copy.deepcopy(model)\n",
    "        \n",
    "        # Store the hyperparameter configuration\n",
    "        best_config = (hidden_dim, dropout, lr, weight_decay)\n",
    "\n",
    "# After all trials complete, print best results\n",
    "print(\"\\nBest Validation Loss:\", best_val_loss)\n",
    "print(\"Best Hyperparameters:\", best_config)\n"
