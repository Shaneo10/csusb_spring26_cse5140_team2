    "# ==================================\n",
    "# 2.3 Final Holdout Evaluation\n",
    "# ==================================\n",
    "\n",
    "# Preprocess the final holdout dataset using the SAME preprocessing pipeline\n",
    "# used during training (important to avoid data leakage).\n",
    "# fit=False ensures we do NOT refit the scaler or encoder.\n",
    "# Instead, we reuse:\n",
    "#   - scaler (feature scaling parameters)\n",
    "#   - encoder (categorical encoding mappings)\n",
    "#   - station_to_idx (station index mapping)\n",
    "X_holdout_processed, y_holdout_log = preprocess_trip_data(\n",
    "    df_final_holdout.drop(columns=['tripduration','trip_id','starttime','stoptime']),\n",
    "    df_final_holdout['tripduration'],\n",
    "    fit=False,\n",
    "    scaler=scaler,\n",
    "    encoder=encoder,\n",
    "    station_to_idx=station_map\n",
    ")\n",
    "\n",
    "# Convert processed holdout features into a PyTorch tensor.\n",
    "# dtype=torch.float32 ensures compatibility with the neural network.\n",
    "# Move tensor to correct device (CPU or GPU).\n",
    "X_holdout_tensor = torch.tensor(\n",
    "    X_holdout_processed.values, dtype=torch.float32\n",
    ").to(device)\n",
    "\n",
    "# Convert holdout target values (log-transformed) into tensor.\n",
    "# .view(-1,1) reshapes to column vector for regression.\n",
    "# Move to correct device.\n",
    "y_holdout_tensor = torch.tensor(\n",
    "    y_holdout_log.values, dtype=torch.float32\n",
    ").view(-1,1).to(device)\n",
    "\n",
    "# Set model to evaluation mode.\n",
    "# This disables dropout and ensures consistent inference behavior.\n",
    "loaded_model.eval()\n",
    "\n",
    "# Compute predictions on holdout set without tracking gradients\n",
    "# (improves efficiency and reduces memory usage).\n",
    "with torch.no_grad():\n",
    "    predictions = loaded_model(X_holdout_tensor)\n",
    "    \n",
    "    # Compute Mean Squared Error on holdout set (log space).\n",
    "    mse = nn.MSELoss()(predictions, y_holdout_tensor).item()\n",
    "\n",
    "# Compute Root Mean Squared Error\n",
    "rmse = mse ** 0.5\n",
    "\n",
    "# Print final evaluation results\n",
    "print(\"=================================\")\n",
    "print(\"Final Holdout Evaluation Results\")\n",
    "print(\"=================================\")\n",
    "print(f\"Holdout MSE  : {mse:.4f}\")\n",
    "print(f\"Holdout RMSE : {rmse:.4f}\")"
   ]
